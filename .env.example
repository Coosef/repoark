# Copy to .env and adjust as needed.

# Host port the panel is reachable on (container always listens on 8000).
HOST_PORT=8765

# Timezone used for the scheduler and displayed timestamps.
TZ=Europe/Istanbul

# Optional: a fixed Fernet key (base64, 32 bytes) so encrypted GitHub tokens
# remain decryptable if you move the data volume to another host.
# Generate one with:  python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# SECRET_KEY=
